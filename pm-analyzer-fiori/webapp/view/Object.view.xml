<mvc:View
    controllerName="com.sap.pm.pmanalyzerfiori.controller.Object"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    <Page
        id="page"
        title="Qualitätsprüfung für Meldung {Notification/NotificationId}"
        showNavButton="true"
        navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiSmallMargin">
                <!-- Sektionen für Meldung, Auftrag, Rückmeldung -->
                <Panel expandable="true" expanded="true" headerText="Instandhaltungsmeldung">
                    <content>
                        <f:SimpleForm layout="ResponsiveGridLayout">
                            <Label text="Meldungsnummer"/><Text text="{Notification/NotificationId}"/>
                            <Label text="Meldungsart"/><Text id="typeText" text="{Notification/NotificationType}"/>
                            <Label text="Beschreibung"/><Text text="{Notification/Description}"/>
                            <Label text="Langtext"/><TextArea id="longText" value="{Notification/LongText}" editable="{view>/editMode}" width="100%" rows="3"/>
                        </f:SimpleForm>
                    </content>
                </Panel>
                <Panel expandable="true" expanded="true" headerText="Instandhaltungsauftrag" class="sapUiSmallMarginTop">
                    <content>
                        <f:SimpleForm layout="ResponsiveGridLayout">
                            <Label text="Auftragsnummer"/><Text text="{Order/OrderId}"/>
                            <Label text="Geplante Vorgänge"/><TextArea value="{Order/Operations}" editable="false" width="100%" rows="3"/>
                            <Label text="Geplante Komponenten"/><Text text="{Order/Components}"/>
                        </f:SimpleForm>
                    </content>
                </Panel>
                <Panel expandable="true" expanded="true" headerText="Durchführung &amp; Rückmeldung" class="sapUiSmallMarginTop">
                    <content>
                        <f:SimpleForm layout="ResponsiveGridLayout">
                            <Label text="Durchgeführte Tätigkeiten"/><TextArea id="activitiesText" value="{Confirmation/Activities}" editable="{view>/editMode}" width="100%" rows="5"/>
                        </f:SimpleForm>
                    </content>
                </Panel>

                <!-- NEU: Sektion für externe Protokolle mit UploadCollection -->
                <Panel expandable="true" expanded="true" headerText="Externe Protokolle" class="sapUiSmallMarginTop">
                    <content>
                        <UploadCollection
                            id="uploadCollection"
                            maximumFileSize="10"
                            multiple="false"
                            instantUpload="false"
                            noDataDescription="Laden Sie hier das externe Wartungsprotokoll (PDF) hoch."
                            change="onFileChange"
                            fileDeleted="onFileDeleted"
                            uploadComplete="onUploadComplete" />
                    </content>
                </Panel>

                <!-- Analyse Buttons & Ergebnisbereich... -->
                <Button
                    id="analyzeButton"
                    text="Qualität analysieren"
                    type="Emphasized"
                    press=".onAnalyzePress"
                    class="sapUiLargeMarginTop"
                    icon="sap-icon://activate"
                    visible="{= !${view>/analysisDone} }" />

                <Button
                    id="reanalyzeButton"
                    text="Korrigierte Texte erneut analysieren"
                    type="Accept"
                    press=".onAnalyzePress"
                    class="sapUiLargeMarginTop"
                    icon="sap-icon://refresh"
                    visible="{view>/analysisDone}" />

                <Panel id="resultsPanel" visible="false" class="sapUiSmallMarginTop" expandable="true" expanded="true" width="auto">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Analyseergebnis"/>
                            <ToolbarSpacer/>
                            <core:Icon id="loadingSpinner" src="sap-icon://synchronize" class="sapUiMediumMarginEnd sap-icon-spin" visible="false"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <f:SimpleForm layout="ResponsiveGridLayout">
                            <f:content>
                                <Label text="Qualitäts-Score"/>
                                <ProgressIndicator id="scoreIndicator" percentValue="0" displayValue="0/100" showValue="true" state="None" />
                                <Label text="Gefundene Probleme"/>
                                <List id="issuesList" items="{analysis>/issues}">
                                    <CustomListItem><Text text="{analysis>}" class="sapUiSmallMargin" /></CustomListItem>
                                </List>
                                <Label text="Zusammenfassung"/>
                                <Text id="summaryText" text="{analysis>/summary}" />
                            </f:content>
                        </f:SimpleForm>
                    </content>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
